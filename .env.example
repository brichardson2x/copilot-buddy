# Required variables
COPILOT_GITHUB_TOKEN=your_copilot_github_token
GH_TOKEN=your_github_cli_token
WEBHOOK_SECRET=your_webhook_secret
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY_PATH=/certs/github/agent.pem
GITHUB_APP_INSTALLATION_ID=your_github_app_installation_id
GITHUB_APP_CLIENT_ID=your_github_app_client_id
BOT_HANDLE=your_bot_github_username
AGENT_MODEL=gpt-4o
HOME_PATH=/home/agent

# Optional variables
# Test-mode startup bypass for local deterministic runs. Default: false
TEST_MODE=false
# Additional prompt instructions prepended to every request.
AGENT_SYSTEM_PROMPT=
# Reviewer username to auto-request on PRs.
REVIEWER_USERNAME=
# SQLite path override. Default: ./data/agent.db
SQLITE_PATH=./data/agent.db
# Service port. Default: 3000
PORT=3000
# Logging level. Default: info
LOG_LEVEL=info
# Fallback default branch for git operations. Default: main
DEFAULT_BRANCH=main
